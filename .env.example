# Personal Agent Environment Configuration

# Gemini API Configuration (default LLM provider)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Configuration (optional fallback provider)
OPENAI_API_KEY=

# Database Configuration
DATABASE_PATH=data/personal_agent.db

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO

# Server Configuration
HOST=127.0.0.1
PORT=8000

# Gmail Integration (Optional)
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# Todoist Integration (Optional)
TODOIST_API_TOKEN=your_todoist_token_here

# Google Calendar Integration (Optional)
GOOGLE_CALENDAR_CREDENTIALS=path_to_credentials.json

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security
SECRET_KEY=your_secret_key_here

# Feature Flags
ENABLE_INTERNET_SEARCH=true
ENABLE_DOCUMENT_QA=true
ENABLE_GMAIL_INTEGRATION=false
ENABLE_CALENDAR_INTEGRATION=false

# Performance Configuration
MAX_CONVERSATION_HISTORY=50
CONVERSATION_SUMMARY_THRESHOLD=20
