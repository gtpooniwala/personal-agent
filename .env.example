# Personal Agent Environment Configuration

# Gemini API Configuration (default LLM provider)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Configuration (optional fallback provider)
OPENAI_API_KEY=

# Langfuse Observability (optional, but recommended)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=false
LANGFUSE_SAMPLE_RATE=1.0

# Database Configuration
DATABASE_URL=postgresql+psycopg://personal_agent:personal_agent@127.0.0.1:5432/personal_agent
# Optional Docker database URL override. Leave unset to derive it from DOCKER_POSTGRES_PORT.
# DATABASE_URL_DOCKER=postgresql+psycopg://personal_agent:personal_agent@postgres:5433/personal_agent
# Host-side tests/evals commonly target the Docker Compose Postgres port.
TEST_DATABASE_URL=postgresql+psycopg://personal_agent:personal_agent@127.0.0.1:5433/personal_agent_test
EVAL_DATABASE_URL=postgresql+psycopg://personal_agent:personal_agent@127.0.0.1:5433/personal_agent_test
POSTGRES_DB=personal_agent
POSTGRES_USER=personal_agent
POSTGRES_PASSWORD=personal_agent

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO

# Server Configuration
HOST=127.0.0.1
PORT=8000

# Docker Port Configuration
# These ports are used directly by the containers and published unchanged on the host.
# Keep the defaults if you want Docker to coexist with native dev on 3000/8000/5432.
DOCKER_API_PORT=8001
DOCKER_FRONTEND_PORT=3001
DOCKER_POSTGRES_PORT=5433
# Optional override for the shared local Postgres data path used by Docker
# Compose. Leave unset to use the default absolute host path
# `${HOME}/.personal-agent/postgres`.
# DOCKER_POSTGRES_DATA_DIR=/absolute/path/to/personal-agent/postgres
# Optional Docker URL overrides. Leave these unset unless you need a non-default hostname.
# DOCKER_FRONTEND_URL=http://localhost:3001
# DOCKER_API_BASE_URL=http://personal-agent:8001

# Gmail / Google OAuth Integration (Optional)
# Configure one Google Cloud OAuth web client for the app, then let each user
# connect Gmail through the app's OAuth flow. Do not store per-user Gmail tokens
# in .env; they are stored encrypted in Postgres.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/api/v1/gmail/callback
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_MASTER_KEY=

# Todoist Integration (Optional)
TODOIST_API_TOKEN=your_todoist_token_here

# Google Calendar Integration (Optional)
GOOGLE_CALENDAR_CREDENTIALS=path_to_credentials.json

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
# API_BASE_URL is not used by the backend or Docker Compose. Frontend/Vercel-only
# proxy setups should set it in the frontend environment instead.
# API_BASE_URL=http://localhost:8000
# Backend auth is optional for local development. Leave AGENT_API_KEY empty to
# keep the local backend open; set a strong token if you want bearer auth enabled.
AGENT_API_KEY=

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security
SECRET_KEY=your_secret_key_here

# Feature Flags
ENABLE_INTERNET_SEARCH=true
ENABLE_DOCUMENT_QA=true
ENABLE_GMAIL_INTEGRATION=true
ENABLE_CALENDAR_INTEGRATION=false

# Performance Configuration
MAX_CONVERSATION_HISTORY=50
CONVERSATION_SUMMARY_THRESHOLD=20
