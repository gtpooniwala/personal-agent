# Personal Agent Environment Configuration

# Gemini API Configuration (default LLM provider)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Configuration (optional fallback provider)
OPENAI_API_KEY=

# Langfuse Observability (optional, but recommended)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=false
LANGFUSE_SAMPLE_RATE=1.0

# Database Configuration
DATABASE_URL=postgresql+psycopg://personal_agent:personal_agent@127.0.0.1:5432/personal_agent
DATABASE_URL_DOCKER=postgresql+psycopg://personal_agent:personal_agent@postgres:5432/personal_agent
# Host-side tests/evals commonly target the Docker Compose Postgres port.
TEST_DATABASE_URL=postgresql+psycopg://personal_agent:personal_agent@127.0.0.1:5433/personal_agent_test
EVAL_DATABASE_URL=postgresql+psycopg://personal_agent:personal_agent@127.0.0.1:5433/personal_agent_test
POSTGRES_DB=personal_agent
POSTGRES_USER=personal_agent
POSTGRES_PASSWORD=personal_agent

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO

# Server Configuration
HOST=127.0.0.1
PORT=8000

# Docker Port Configuration (avoids conflicts with local dev server)
DOCKER_API_PORT=8001
DOCKER_FRONTEND_PORT=3001
DOCKER_POSTGRES_PORT=5433
DOCKER_FRONTEND_URL=http://localhost:3001
DOCKER_NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1
DOCKER_NEXT_PUBLIC_RUNTIME_API_BASE_URL=http://localhost:8001

# Gmail Integration (Optional)
# Leave these unset to use the built-in defaults:
# - local backend: backend/data/gmail/{client_secret.json,token.pickle}
# - Docker Compose: /app/data/gmail/{client_secret.json,token.pickle}
# Only set these if you need a custom path. When overriding Docker Compose,
# use container paths, not host paths.
# GMAIL_CREDENTIALS_PATH=/app/data/gmail/client_secret.json
# GMAIL_TOKEN_PATH=/app/data/gmail/token.pickle

# Todoist Integration (Optional)
TODOIST_API_TOKEN=your_todoist_token_here

# Google Calendar Integration (Optional)
GOOGLE_CALENDAR_CREDENTIALS=path_to_credentials.json

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_RUNTIME_API_BASE_URL=http://localhost:8000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security
SECRET_KEY=your_secret_key_here

# Feature Flags
ENABLE_INTERNET_SEARCH=true
ENABLE_DOCUMENT_QA=true
ENABLE_GMAIL_INTEGRATION=true
ENABLE_CALENDAR_INTEGRATION=false

# Performance Configuration
MAX_CONVERSATION_HISTORY=50
CONVERSATION_SUMMARY_THRESHOLD=20
