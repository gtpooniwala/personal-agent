#!/usr/bin/env bash
set -euo pipefail

BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if [ "$BRANCH" = "main" ]; then
  echo "Push blocked: do not push from main."
  exit 1
fi

if ! git fetch origin main >/dev/null 2>&1; then
  echo "Push blocked: failed to fetch origin/main. Fix remote connectivity and retry."
  exit 1
fi

BEHIND="$(git rev-list --left-right --count origin/main...HEAD | awk '{print $1}')"
if [ "${BEHIND}" -gt 0 ]; then
  echo "Push blocked: branch is behind origin/main by ${BEHIND} commit(s). Run scripts/sync_main.sh"
  exit 1
fi

exit 0
