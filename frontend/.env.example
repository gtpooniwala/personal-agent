API_BASE_URL=http://127.0.0.1:8000
AGENT_API_KEY=local-dev-token

# NextAuth — run `openssl rand -hex 32` to generate AUTH_SECRET
AUTH_SECRET=<run: openssl rand -hex 32>

# Google OAuth (create at console.cloud.google.com → APIs & Services → Credentials)
# Add http://localhost:3000/api/auth/callback/google as an authorised redirect URI
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of Google account emails allowed to sign in
AUTH_ALLOWED_EMAILS=you@gmail.com

# For local development only: bypass auth entirely when AUTH_ALLOWED_EMAILS is not set
ALLOW_EMPTY_AUTH=true
