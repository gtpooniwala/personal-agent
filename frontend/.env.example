API_BASE_URL=http://127.0.0.1:8000
AGENT_API_KEY=local-dev-token
# Passwords must be SHA-256 hashed. For example, "password123" is 
# ef92b778bafe771e89245b89ecbc08a44a4e166c06659911881f383d4473e94f
AUTH_USERS=admin:ef92b778bafe771e89245b89ecbc08a44a4e166c06659911881f383d4473e94f
AUTH_SECRET=random_secret_key_at_least_32_characters
