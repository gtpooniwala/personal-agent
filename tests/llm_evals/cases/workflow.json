{
  "schema_version": "1.0",
  "suite": "workflow",
  "description": "Multi-step and fallback workflow behavior checks.",
  "cases": [
    {
      "id": "multi_tool_single_turn",
      "set": "core",
      "description": "Combined requests should trigger multiple relevant tools.",
      "turns": [
        {
          "message": "What is 9 * 7 and what time is it?"
        }
      ],
      "expected": {
        "per_turn": [
          {
            "must_call": [
              "calculator",
              "current_time"
            ],
            "response_contains": [
              "63",
              "time"
            ]
          }
        ]
      }
    },
    {
      "id": "document_fallback_without_selection",
      "set": "core",
      "description": "Document queries without selected docs should return clear fallback guidance.",
      "turns": [
        {
          "message": "What does my uploaded contract say about termination?",
          "selected_documents": []
        }
      ],
      "expected": {
        "per_turn": [
          {
            "response_contains": [
              "contract"
            ],
            "response_contains_any": [
              "no documents",
              "don't have access",
              "couldn't find"
            ]
          }
        ],
        "by_mode": {
          "mock": {
            "per_turn": [
              {
                "response_contains": [
                  "no documents are currently selected"
                ]
              }
            ]
          }
        }
      }
    },
    {
      "id": "iterative_math_then_time",
      "set": "core",
      "description": "Workflow should stay coherent over multiple turns in one conversation.",
      "turns": [
        {
          "message": "Calculate 100 / 4"
        },
        {
          "message": "Now what time is it?"
        }
      ],
      "expected": {
        "per_turn": [
          {
            "response_contains": [
              "25"
            ]
          }
        ],
        "overall_must_not_call": ["search_documents"],
        "by_mode": {
          "live": {
            "per_turn": [
              {
                "response_contains": [
                  "25"
                ]
              },
              {
                "response_contains_any": [
                  "am",
                  "pm",
                  "time"
                ]
              }
            ]
          },
          "mock": {
            "per_turn": [
              {
                "must_call": [
                  "calculator"
                ],
                "response_contains": [
                  "25"
                ]
              },
              {
                "must_call": [
                  "current_time"
                ],
                "response_contains": [
                  "time"
                ]
              }
            ],
            "overall_must_not_call": [
              "search_documents"
            ]
          }
        }
      }
    },
    {
      "id": "iterative_document_then_latest_news",
      "set": "extended",
      "description": "A mixed conversation should route documents first and internet later.",
      "turns": [
        {
          "message": "Search my uploaded contract for renewal terms.",
          "selected_documents": [
            "doc-123"
          ]
        },
        {
          "message": "Now search the internet for today's top AI headlines."
        }
      ],
      "expected": {
        "by_mode": {
          "mock": {
            "per_turn": [
              {
                "must_call": [
                  "search_documents"
                ],
                "must_not_call": [
                  "internet_search"
                ]
              },
              {
                "must_call": [
                  "internet_search"
                ],
                "response_contains": [
                  "search"
                ]
              }
            ]
          },
          "live": {
            "per_turn": [
              {
                "must_call": [
                  "search_documents"
                ]
              },
              {
                "must_call": [
                  "internet_search"
                ]
              }
            ]
          }
        }
      }
    }
  ]
}
