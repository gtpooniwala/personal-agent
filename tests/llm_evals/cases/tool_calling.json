{
  "schema_version": "1.0",
  "suite": "tool_calling",
  "description": "Single-turn tool routing behavior checks.",
  "cases": [
    {
      "id": "calculator_basic",
      "set": "core",
      "description": "Math queries should route to calculator.",
      "turns": [
        {
          "message": "What is 15 + 27?"
        }
      ],
      "expected": {
        "per_turn": [
          {
            "must_call": [
              "calculator"
            ],
            "must_not_call": [
              "current_time",
              "internet_search"
            ],
            "response_contains": [
              "42"
            ]
          }
        ]
      }
    },
    {
      "id": "current_time_basic",
      "set": "core",
      "description": "Time queries should use current_time.",
      "turns": [
        {
          "message": "What time is it right now?"
        }
      ],
      "expected": {
        "per_turn": [
          {
            "must_call": [
              "current_time"
            ],
            "must_not_call": [
              "calculator"
            ]
          }
        ],
        "by_mode": {
          "mock": {
            "per_turn": [
              {
                "must_call": [
                  "current_time"
                ],
                "must_not_call": [
                  "calculator"
                ],
                "response_contains": [
                  "time"
                ]
              }
            ]
          }
        }
      }
    },
    {
      "id": "greeting_no_tools",
      "set": "core",
      "description": "Simple greetings should avoid unnecessary tools.",
      "turns": [
        {
          "message": "Hello there"
        }
      ],
      "expected": {
        "per_turn": [
          {
            "must_not_call": [
              "calculator",
              "current_time",
              "internet_search",
              "search_documents"
            ],
            "response_contains": [
              "hello"
            ]
          }
        ]
      }
    },
    {
      "id": "internet_search_routing",
      "set": "core",
      "description": "Queries about latest news should route to internet_search.",
      "turns": [
        {
          "message": "Search the internet for today's top AI news headlines."
        }
      ],
      "expected": {
        "per_turn": [
          {
            "must_call": [
              "internet_search"
            ]
          }
        ],
        "by_mode": {
          "mock": {
            "per_turn": [
              {
                "must_call": [
                  "internet_search"
                ],
                "response_contains": [
                  "search"
                ]
              }
            ]
          }
        }
      }
    },
    {
      "id": "document_search_selected_docs",
      "set": "core",
      "description": "Document-specific queries with selected docs should route to search_documents only.",
      "turns": [
        {
          "message": "Search my uploaded contract for termination details.",
          "selected_documents": [
            "doc-123"
          ]
        }
      ],
      "expected": {
        "per_turn": [
          {
            "must_call": [
              "search_documents"
            ],
            "must_not_call": [
              "calculator",
              "current_time",
              "internet_search"
            ],
            "response_contains": [
              "document"
            ]
          }
        ],
        "by_mode": {
          "mock": {
            "per_turn": [
              {
                "must_call": [
                  "search_documents"
                ],
                "must_not_call": [
                  "calculator",
                  "current_time",
                  "internet_search"
                ],
                "response_contains": [
                  "selected documents"
                ]
              }
            ]
          }
        }
      }
    },
    {
      "id": "calculator_exponentiation",
      "set": "extended",
      "description": "Exponentiation queries should route to calculator and produce numeric output.",
      "turns": [
        {
          "message": "What is 2 ** 8?"
        }
      ],
      "expected": {
        "per_turn": [
          {
            "must_call": [
              "calculator"
            ],
            "response_contains": [
              "256"
            ]
          }
        ]
      }
    },
    {
      "id": "document_phrase_does_not_trigger_internet",
      "set": "extended",
      "description": "Document-search phrasing should not accidentally trigger internet_search.",
      "turns": [
        {
          "message": "Search my uploaded file for pricing terms.",
          "selected_documents": [
            "doc-456"
          ]
        }
      ],
      "expected": {
        "per_turn": [
          {
            "must_call": [
              "search_documents"
            ],
            "must_not_call": [
              "internet_search"
            ]
          }
        ]
      }
    },
    {
      "id": "generic_capability_prompt_avoids_tools",
      "set": "extended",
      "description": "Generic capability questions should not trigger tools.",
      "turns": [
        {
          "message": "What can you help me with?"
        }
      ],
      "expected": {
        "per_turn": [
          {
            "must_not_call": [
              "calculator",
              "current_time",
              "internet_search",
              "search_documents"
            ]
          }
        ]
      }
    }
  ]
}
