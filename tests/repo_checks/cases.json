[
  {
    "id": "legacy_agent_removed",
    "type": "path_absent",
    "path": "backend/agent",
    "description": "Legacy backend/agent module has been removed"
  },
  {
    "id": "legacy_memory_removed",
    "type": "path_absent",
    "path": "backend/orchestrator/memory.py",
    "description": "Legacy orchestrator memory module has been removed"
  },
  {
    "id": "stray_config_removed",
    "type": "path_absent",
    "path": "backend/config/settings.py",
    "description": "Stray config shim has been removed"
  },
  {
    "id": "core_import_hygiene",
    "type": "not_contains",
    "path": "backend/orchestrator/core.py",
    "pattern": "from services.document_service import doc_processor",
    "description": "Core orchestrator uses fully-qualified backend service imports"
  },
  {
    "id": "search_docs_import_hygiene",
    "type": "not_contains",
    "path": "backend/orchestrator/tools/search_documents.py",
    "pattern": "from services.document_service import doc_processor",
    "description": "Document search tool uses fully-qualified backend service imports"
  },
  {
    "id": "docker_health_endpoint",
    "type": "contains",
    "path": "Dockerfile",
    "pattern": "/api/v1/health",
    "description": "Docker healthcheck points to versioned API health endpoint"
  },
  {
    "id": "compose_health_endpoint",
    "type": "contains",
    "path": "docker-compose.yml",
    "pattern": "/api/v1/health",
    "description": "Compose healthcheck points to versioned API health endpoint"
  },
  {
    "id": "setup_env_path",
    "type": "contains",
    "path": "setup.sh",
    "pattern": "cp .env.example .env",
    "description": "Setup script configures root-level .env"
  },
  {
    "id": "requirements_numpy",
    "type": "contains",
    "path": "backend/requirements.txt",
    "pattern": "numpy==",
    "description": "Core search dependency numpy is pinned"
  },
  {
    "id": "requirements_requests",
    "type": "contains",
    "path": "backend/requirements.txt",
    "pattern": "requests==",
    "description": "Web search dependency requests is pinned"
  },
  {
    "id": "requirements_openai",
    "type": "contains",
    "path": "backend/requirements.txt",
    "pattern": "openai==",
    "description": "Direct OpenAI client dependency is pinned"
  },
  {
    "id": "tests_readme_present",
    "type": "contains",
    "path": "tests/README.md",
    "pattern": "Run Scenario Test Script",
    "description": "Tests README documents the scenario test workflow"
  },
  {
    "id": "agents_contract_present",
    "type": "contains",
    "path": "AGENTS.md",
    "pattern": "shared root checkout is control-plane/admin-only",
    "description": "Repo-local AGENTS contract documents the managed slot workflow"
  },
  {
    "id": "agent_shim_points_to_agents",
    "type": "contains",
    "path": "AGENT.md",
    "pattern": "AGENTS.md",
    "description": "Legacy AGENT shim points to AGENTS.md"
  },
  {
    "id": "claude_contract_points_to_agents",
    "type": "contains",
    "path": "CLAUDE.md",
    "pattern": "AGENTS.md",
    "description": "Claude contract points to AGENTS.md as the canonical source"
  },
  {
    "id": "slot_workflow_doc_present",
    "type": "contains",
    "path": "docs/WORKTREE_SLOTS.md",
    "pattern": "scripts/start-agent.sh codex --app",
    "description": "Worktree slot documentation covers Codex app launch flow"
  },
  {
    "id": "workflow_skill_requires_issue_backed_branches",
    "type": "contains",
    "path": "skills/repo-workflow-env/SKILL.md",
    "pattern": "do not invent issue-less scratch branches",
    "description": "Repo workflow skill blocks issue-less scratch branches"
  },
  {
    "id": "commit_skill_requires_issue_backed_branches",
    "type": "contains",
    "path": "skills/repo-commit-pr-flow/SKILL.md",
    "pattern": "Branch must remain issue-backed",
    "description": "Repo commit/PR skill keeps the issue-backed branch contract explicit"
  }
]
